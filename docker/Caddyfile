# docker/Caddyfile — bearer-token auth gateway in front of the senda
# runtime. Used when $MESH_AUTH_TOKEN is set (entrypoint selects this file
# and binds senda to 127.0.0.1).
#
#     {$GATEWAY_PORT} ──Caddy (auth)──> 127.0.0.1:{$INTERNAL_PORT}  (OpenAI API)
#                     └──────────────> 127.0.0.1:{$CONSOLE_PORT}    (admin console)
#
# Open without auth:
#   /api/status — join-token endpoint; new nodes need this to bootstrap
#                 into the P2P mesh. No inference, no cost.
#   /v1/models  — model-name list; platform health checks don't need the token.
#
# Gated with Bearer:
#   /v1/*       — OpenAI-compatible inference API
#   /api/*      — admin console API
#   everything else → 401

{
	auto_https off
	admin off
}

{$SITE_ADDR::{$GATEWAY_PORT}} {
	# P2P bootstrap — always open so new contributors can join the mesh.
	@join path /api/status
	handle @join {
		reverse_proxy 127.0.0.1:{$CONSOLE_PORT}
	}

	# Health check — unauthenticated so platform monitors don't need the token.
	@health path /v1/models
	handle @health {
		reverse_proxy 127.0.0.1:{$INTERNAL_PORT}
	}

	# Authenticated paths.
	@authed header Authorization "Bearer {$MESH_AUTH_TOKEN}"
	handle @authed {
		@console_path path /api/*
		handle @console_path {
			reverse_proxy 127.0.0.1:{$CONSOLE_PORT}
		}
		handle {
			reverse_proxy 127.0.0.1:{$INTERNAL_PORT}
		}
	}

	respond "Unauthorized" 401
}
