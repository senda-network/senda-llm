# senda CPU full-node image (includes llama.cpp CPU backend)
# Supports linux/amd64 and linux/arm64.
#
# Build:  DOCKER_BUILDKIT=1 docker build -f docker/Dockerfile.cpu -t senda:cpu .
# Run:    docker run --rm -p 9337:9337 -v ~/.models:/root/.models -e APP_MODE=worker senda:cpu
#         docker run --rm -p 9337:9337 -p 3131:3131 -e APP_MODE=worker -e MESH_HEADLESS=1 senda:cpu  # API-only
#
# Binaries at /usr/local/lib/senda/bin/:
#   rpc-server-cpu
#   llama-server-cpu
#   llama-moe-split (unsuffixed — same across flavors)
#
# llama.cpp revision: tracked at /usr/local/share/senda/llama-revision.txt
# Source: ggml-org/llama.cpp upstream pin plus Mesh-LLM patch queue

# syntax=docker/dockerfile:1.7

FROM node:24-alpine AS ui-builder
WORKDIR /app
COPY senda/ui/package.json senda/ui/package-lock.json ./
RUN --mount=type=cache,id=npm-cache,target=/root/.npm \
    npm ci
COPY senda/ui/ ./
RUN npm run build
# Output: /app/dist

FROM debian:bookworm-slim AS rust-deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git cmake ninja-build pkg-config libssl-dev libdbus-1-dev python3 build-essential \
    && rm -rf /var/lib/apt/lists/*
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --profile minimal
ENV PATH="/root/.cargo/bin:$PATH"
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    cargo install cargo-chef --version 0.1.68 --locked
WORKDIR /src
# Satisfy GitHub Actions preflight checks (exact strings required)
COPY Cargo.toml Cargo.lock ./
COPY senda/Cargo.toml senda/Cargo.toml
COPY senda/build.rs senda/build.rs
COPY senda/plugin/Cargo.toml senda/plugin/Cargo.toml
COPY senda/plugin/build.rs senda/plugin/build.rs
COPY senda/proto/ senda/proto/
# Satisfy Cargo workspace member resolution
COPY senda/ senda/
COPY senda-client/ senda-client/
COPY mesh-api/ mesh-api/
COPY mesh-host-core/ mesh-host-core/
COPY mesh-api-ffi/ mesh-api-ffi/
COPY senda-test-harness/ senda-test-harness/
COPY tools/xtask/ tools/xtask/
RUN mkdir -p senda/ui/dist && echo '<html></html>' > senda/ui/dist/index.html
RUN cargo chef prepare --recipe-path recipe.json
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,target=/src/target \
    cargo chef cook --release --locked --recipe-path recipe.json

FROM rust-deps AS rust-builder
WORKDIR /src
RUN rm -rf senda/ui/dist
COPY --from=ui-builder /app/dist senda/ui/dist
# Restore real build scripts (cargo-chef stubs them during cook)
# Satisfy GitHub Actions preflight checks (exact strings required)
COPY Cargo.toml Cargo.lock ./
COPY senda/Cargo.toml senda/Cargo.toml
COPY senda/build.rs senda/build.rs
COPY senda/plugin/Cargo.toml senda/plugin/Cargo.toml
COPY senda/plugin/build.rs senda/plugin/build.rs
COPY senda/proto/ senda/proto/
# Satisfy Cargo workspace member resolution
COPY senda/ senda/
COPY senda-client/ senda-client/
COPY mesh-api/ mesh-api/
COPY mesh-host-core/ mesh-host-core/
COPY mesh-api-ffi/ mesh-api-ffi/
COPY senda-test-harness/ senda-test-harness/
COPY tools/xtask/ tools/xtask/
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,target=/src/target \
    cargo build --release --locked -p senda && \
    mkdir -p /out && \
    cp /src/target/release/senda /out/senda

FROM debian:bookworm-slim AS llama-builder-cpu
RUN apt-get update && apt-get install -y --no-install-recommends \
    cmake ninja-build build-essential git ca-certificates \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /src
COPY scripts/prepare-llama.sh scripts/prepare-llama.sh
COPY third_party/llama.cpp/ third_party/llama.cpp/
RUN scripts/prepare-llama.sh pinned
RUN cd llama.cpp && git rev-parse HEAD > /tmp/llama-sha.txt
RUN cd llama.cpp && \
    cmake -B build -G Ninja \
      -DGGML_RPC=ON \
      -DBUILD_SHARED_LIBS=OFF \
      -DLLAMA_OPENSSL=OFF \
      -DCMAKE_BUILD_TYPE=Release \
      -DGGML_CUDA=OFF \
      -DGGML_HIP=OFF \
      -DGGML_VULKAN=OFF \
      -DGGML_METAL=OFF \
      -DGGML_NATIVE=OFF && \
    cmake --build build --target rpc-server llama-server llama-moe-split && \
    mkdir -p /out && \
    cp build/bin/rpc-server /out/rpc-server-cpu && \
    cp build/bin/llama-server /out/llama-server-cpu && \
    cp build/bin/llama-moe-split /out/llama-moe-split

FROM debian:bookworm-slim AS runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates libgomp1 libdbus-1-3 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=rust-builder /out/senda /usr/local/bin/senda
COPY --from=llama-builder-cpu /out/rpc-server-cpu /usr/local/lib/senda/bin/rpc-server-cpu
COPY --from=llama-builder-cpu /out/llama-server-cpu /usr/local/lib/senda/bin/llama-server-cpu
COPY --from=llama-builder-cpu /out/llama-moe-split /usr/local/lib/senda/bin/llama-moe-split
COPY --from=llama-builder-cpu /tmp/llama-sha.txt /usr/local/share/senda/llama-revision.txt
LABEL io.senda.llama-revision-file="/usr/local/share/senda/llama-revision.txt"
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ARG CMD=console
ENV APP_MODE=${CMD}
EXPOSE 3131 9337
ENTRYPOINT ["/entrypoint.sh"]
