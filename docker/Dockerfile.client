# closedmesh client-only image (no llama.cpp, no GPU)
# Supersedes fly/Dockerfile content. Supports linux/amd64 and linux/arm64.
#
# Build:  DOCKER_BUILDKIT=1 docker build -f docker/Dockerfile.client -t closedmesh:client .
# Run:    docker run --rm -p 3131:3131 -p 9337:9337 -e APP_MODE=console closedmesh:client
#         docker run --rm -p 3131:3131 -p 9337:9337 -e APP_MODE=console -e MESH_HEADLESS=1 closedmesh:client  # API-only
#
# Modes (via APP_MODE env):
#   console  — API on 9337 + web console on 3131 (default; UI always included)
#   worker  — unsupported in this image; use a full-node image (:cpu/:cuda/:rocm/:vulkan)
#
# Modifiers (via env):
#   MESH_HEADLESS=1  — disable web UI routes; keep /api/* and /v1/* accessible

# syntax=docker/dockerfile:1.7

FROM node:24-alpine AS ui-builder
WORKDIR /app
COPY closedmesh/ui/package.json closedmesh/ui/package-lock.json ./
RUN --mount=type=cache,id=npm-cache,target=/root/.npm \
    npm ci
COPY closedmesh/ui/ ./
RUN npm run build
# Output: /app/dist

FROM debian:bookworm-slim AS rust-deps
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git cmake ninja-build pkg-config libssl-dev libdbus-1-dev python3 build-essential \
    && rm -rf /var/lib/apt/lists/*
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable --profile minimal
ENV PATH="/root/.cargo/bin:$PATH"
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    cargo install cargo-chef --version 0.1.68 --locked
WORKDIR /src
# Satisfy GitHub Actions preflight checks (exact strings required)
COPY Cargo.toml Cargo.lock ./
COPY closedmesh/Cargo.toml closedmesh/Cargo.toml
COPY closedmesh/build.rs closedmesh/build.rs
COPY closedmesh/plugin/Cargo.toml closedmesh/plugin/Cargo.toml
COPY closedmesh/plugin/build.rs closedmesh/plugin/build.rs
COPY closedmesh/proto/ closedmesh/proto/
# Satisfy Cargo workspace member resolution
COPY closedmesh/ closedmesh/
COPY closedmesh-client/ closedmesh-client/
COPY mesh-api/ mesh-api/
COPY mesh-host-core/ mesh-host-core/
COPY mesh-api-ffi/ mesh-api-ffi/
COPY closedmesh-test-harness/ closedmesh-test-harness/
COPY tools/xtask/ tools/xtask/
RUN mkdir -p closedmesh/ui/dist && echo '<html></html>' > closedmesh/ui/dist/index.html
RUN cargo chef prepare --recipe-path recipe.json
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,target=/src/target \
    cargo chef cook --release --locked --recipe-path recipe.json

FROM rust-deps AS rust-builder
WORKDIR /src
RUN rm -rf closedmesh/ui/dist
COPY --from=ui-builder /app/dist closedmesh/ui/dist
# Restore real build scripts (cargo-chef stubs them during cook)
# Satisfy GitHub Actions preflight checks (exact strings required)
COPY Cargo.toml Cargo.lock ./
COPY closedmesh/Cargo.toml closedmesh/Cargo.toml
COPY closedmesh/build.rs closedmesh/build.rs
COPY closedmesh/plugin/Cargo.toml closedmesh/plugin/Cargo.toml
COPY closedmesh/plugin/build.rs closedmesh/plugin/build.rs
COPY closedmesh/proto/ closedmesh/proto/
# Satisfy Cargo workspace member resolution
COPY closedmesh/ closedmesh/
COPY closedmesh-client/ closedmesh-client/
COPY mesh-api/ mesh-api/
COPY mesh-host-core/ mesh-host-core/
COPY mesh-api-ffi/ mesh-api-ffi/
COPY closedmesh-test-harness/ closedmesh-test-harness/
COPY tools/xtask/ tools/xtask/
RUN --mount=type=cache,target=/root/.cargo/registry \
    --mount=type=cache,target=/root/.cargo/git \
    --mount=type=cache,target=/src/target \
    cargo build --release --locked -p closedmesh && \
    mkdir -p /out && \
    cp /src/target/release/closedmesh /out/closedmesh

FROM debian:bookworm-slim AS runtime
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates libgomp1 libdbus-1-3 \
    && rm -rf /var/lib/apt/lists/*
COPY --from=rust-builder /out/closedmesh /usr/local/bin/closedmesh
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ARG CMD=console
ENV APP_MODE=${CMD}
EXPOSE 3131 9337
ENTRYPOINT ["/entrypoint.sh"]
